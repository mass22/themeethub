// https://pris.ly/d/prisma-schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id              String   @id
  title           String
  slug            String   @unique
  date            DateTime
  location        String?
  description     String?
  bannerImageUrl  String?
  lumaEventId     String?
  zoomUrl         String?
  replayUrl       String?
  statsJson       String?
  speakersJson    String   @default("[]")
  sponsorsJson    String   @default("[]")
  contractorsJson String   @default("[]")
  toolsJson       String   @default("[]")
  venueId         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  promoItems     PromoItem[]
  logisticsItems LogisticsItem[]
  socialPosts    SocialPost[]
}

model Speaker {
  id          String   @id
  name        String
  role        String?
  bio         String?
  avatar      String?
  contactId   String?
  socialsJson String?
  topicsJson  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contact Contact? @relation("SpeakerContact", fields: [contactId], references: [id])
}

model Request {
  id                        String    @id
  name                      String
  email                     String
  type                      String
  companyName               String?
  role                      String?
  status                    String   @default("new")
  createdAt                 DateTime @default(now())
  exploringCallEmailSentAt  DateTime?
  updatedAt                 DateTime @updatedAt
}

model Contact {
  id        String   @id
  name      String
  email     String
  phone     String?
  tagsJson  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sponsors     Sponsor[]       @relation("SponsorContact")
  venues       Venue[]        @relation("VenueContact")
  contractors  Contractor[]   @relation("ContractorContact")
  speakers     Speaker[]      @relation("SpeakerContact")
  logisticsItems LogisticsItem[] @relation("LogisticsOwner")
  participations Participation[] @relation("ParticipationOwner")
}

model Sponsor {
  id           String   @id
  companyName  String
  tier         String?
  contactId    String?
  contactName  String?
  contactEmail String?
  logoUrl      String?
  websiteUrl   String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contact Contact? @relation("SponsorContact", fields: [contactId], references: [id])
}

model Venue {
  id        String   @id
  name      String
  address   String?
  capacity  Int?
  contactId String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact Contact? @relation("VenueContact", fields: [contactId], references: [id])
}

model Contractor {
  id        String   @id
  name      String
  role      String?
  contactId String?
  rate      Float?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact Contact? @relation("ContractorContact", fields: [contactId], references: [id])
}

model Tool {
  id        String   @id
  name      String
  type      String?
  url       String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PromoItem {
  id          String   @id
  eventId     String?
  title       String
  channel     String?
  dueAt       DateTime?
  status      String   @default("todo")
  copy        String?
  assetLinksJson String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event Event? @relation(fields: [eventId], references: [id])
}

model LogisticsItem {
  id              String   @id
  eventId         String
  name            String
  category        String?
  ownerContactId String?
  status          String   @default("todo")
  dueAt           DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id])
  owner Contact? @relation("LogisticsOwner", fields: [ownerContactId], references: [id])
}

model SocialPost {
  id             String   @id
  eventId        String?
  platform       String?
  copy           String?
  scheduledAt    DateTime?
  status         String   @default("draft")
  assetLinksJson String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  event Event? @relation(fields: [eventId], references: [id])
}

model ExternalCommunity {
  id        String   @id
  name      String
  url       String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  externalEvents ExternalEvent[]
}

model ExternalEvent {
  id          String   @id
  communityId String
  title       String
  startAt     DateTime
  location    String?
  url         String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  community     ExternalCommunity @relation(fields: [communityId], references: [id])
  participations Participation[]
}

model Participation {
  id               String   @id
  externalEventId  String
  intent           String
  ownerContactId   String?
  status           String   @default("planned")
  followUpDueAt    DateTime?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  externalEvent ExternalEvent @relation(fields: [externalEventId], references: [id])
  owner         Contact?     @relation("ParticipationOwner", fields: [ownerContactId], references: [id])
}

// Better Auth (magic link, sessions)
model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
