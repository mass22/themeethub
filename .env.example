# Database (required when useMocks is false)
# PostgreSQL (direct ou Prisma Postgres / Accelerate selon ta Console)
DATABASE_URL="file:./dev.db"

# Runtime config: use mock JSON files instead of database
NUXT_USE_MOCKS=true

# Optional: Luma API key for event sync
NUXT_LUMA_API_KEY=""
# Optional: YouTube API key
NUXT_YOUTUBE_API_KEY=""
# Cal.com booking links
NUXT_CAL_SPONSOR_LINK=""
NUXT_CAL_SPEAKER_LINK=""
# Email sender address
NUXT_FROM_EMAIL=""

# Better Auth (back office — lien magique)
# Générer : openssl rand -base64 32
BETTER_AUTH_SECRET=""
# URL publique de l’app (dev / prod)
BETTER_AUTH_URL="http://localhost:3000"
# Optionnel : Resend (sinon le lien est loggé en console)
RESEND_API_KEY=""
# Optionnel : liste d’e-mails autorisés (séparés par des virgules). Vide = tous.
NUXT_AUTH_ALLOWED_EMAILS=""
# Connexion GitHub (OAuth) : créer une OAuth App, callback = {BETTER_AUTH_URL}/api/auth/callback/github
# Activer le bouton sur la page login :
NUXT_PUBLIC_GITHUB_AUTH="true"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
